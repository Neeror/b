{
  "name": "neuro-desk",
  "version": "1.0.0",
  "description": "NeuroDesk Ultra AI - Smart Programmer Desk",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/server/index.ts",
    "start": "node dist/server/index.js",
    "client:dev": "vite --config client/vite.config.ts",
    "client:build": "tsc -p client/tsconfig.json && vite build --config client/vite.config.ts",
    "client:preview": "vite preview --config client/vite.config.ts",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "mongoose": "^8.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.0.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
